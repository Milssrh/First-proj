// 1. Классы «Кружка» и «Человек». Дайте возможность человеку пить из кружки.
class Kruzhka {
  int voda = 100; // сколько воды в кружке (в мл)
  
  void pit() {
    if (voda >= 10) {
      voda -= 10;
      print('Сделал глоток. Осталось $voda мл');
    } else {
      print('Кружка пуста!');
    }
  }
}

class Chelovek {
  String name;
  Chelovek(this.name);
  void pitIzKruzhki(Kruzhka kruzhka) {
    print('$name пьет из кружки');
    kruzhka.pit();
  }
}

// 2. Реализуйте класс «Шкаф», в состав которого входит несколько систем хранения. У пользователя должна быть возможность поместить вещи в шкаф и забрать их оттуда.
class Polka {
  List<String> veshi = [];
  void polozhit(String vesh) {
    veshi.add(vesh);
    print('Положил $vesh на полку');
  }
  
  String zabrat(String vesh) {
    if (veshi.contains(vesh)) {
      veshi.remove(vesh);
      print('Забрал $vesh с полки');
      return vesh;
    } else {
      print('$vesh не найдено');
      return '';
    }
  }
  
  void pokazatVeshi() {
    print('На полке: $veshi');
  }
}

class Shkaf {
  List<Polka> polki = [];
  Shkaf(int kolichestvoPolok) {
    for (int i = 0; i < kolichestvoPolok; i++) {
      polki.add(Polka());
    }
  }
  
  void polozhitVShkaf(int nomerPolki, String vesh) {
    if (nomerPolki < polki.length) {
      polki[nomerPolki].polozhit(vesh);
    } else {
      print('Такой полки нет');
    }
  }
  
  void zabratIzShkafa(int nomerPolki, String vesh) {
    if (nomerPolki < polki.length) {
      polki[nomerPolki].zabrat(vesh);
    } else {
      print('Такой полки нет');
    }
  }
}

// 3. Реализуйте класс «Гриф» и «Блин». На гриф с левой и с правой стороны можно навешивать блины. В конструкторе класса «Гриф» передавайте параметр максимальной загрузки грифа по весу.
class Blin {
  int ves;
  Blin(this.ves);
}

class Grif {
  int maxVes;
  int tekushiyVes = 0;
  List<Blin> levieBliny = [];
  List<Blin> pravyeBliny = [];
  
  Grif(this.maxVes);
  bool navesitBl(Blin blin, String storona) {
    if (tekushiyVes + blin.ves <= maxVes) {
      if (storona == 'levo') {
        levieBliny.add(blin);
      } else if (storona == 'pravo') {
        pravyeBliny.add(blin);
      }
      tekushiyVes += blin.ves;
      print('Навесил блин ${blin.ves}кг на $storona сторону');
      return true;
    } else {
      print('Превышен максимальный вес!');
      return false;
    }
  }
  
  void pokazatVes() {
    print('Текущий вес: $tekushiyVes кг из $maxVes кг');
  }
}

// 4. Реализуйте класс для конвертации денег из одной валюты в другую.
class KonverterValut {
  double kursUSD;
  double kursEUR;
  
  KonverterValut(this.kursUSD, this.kursEUR);
  
  double rubVUsd(double rub) {
    return rub / kursUSD;
  }
  
  double rubVEur(double rub) {
    return rub / kursEUR;
  }
  
  double usdVRub(double usd) {
    return usd * kursUSD;
  }
  
  double eurVRub(double eur) {
    return eur * kursEUR;
  }
}

// 5. Посредством дженериков реализуйте класс «Гараж», где можно хранить различные объекты.
class Garazh<T> {
  List<T> predmety = [];
  
  void polozhit(T predmet) {
    predmety.add(predmet);
    print('Положил в гараж: $predmet');
  }
  
  T vzat() {
    if (predmety.isNotEmpty) {
      T predmet = predmety.removeLast();
      print('Взял из гаража: $predmet');
      return predmet;
    } else {
      print('Гараж пуст');
      return null as T;
    }
  }
  
  void pokazatVse() {
    print('В гараже: $predmety');
  }
}

// 6. Напишите класс, в котором перегружены все базовые арифметические операции и класс. Проверьте его работу.
class Chislo {
  int znachenie;
  
  Chislo(this.znachenie);
  
  Chislo operator +(Chislo other) {
    return Chislo(znachenie + other.znachenie);
  }
  
  Chislo operator -(Chislo other) {
    return Chislo(znachenie - other.znachenie);
  }
  
  Chislo operator *(Chislo other) {
    return Chislo(znachenie * other.znachenie);
  }
  
  double operator /(Chislo other) {
    return znachenie / other.znachenie;
  }
  
  @override
  String toString() {
    return '$znachenie';
  }
}

// 7. Напишите класс «Автомобиль», для таких состояний, как: стоп, ехать, повернуть, используйте перечисления.
enum Sostoianie { stop, ehat, povorot }

class Avtomobil {
  Sostoianie sostoianie = Sostoianie.stop;
  
  void ustanovitSostoianie(Sostoianie novoe) {
    sostoianie = novoe;
    if (sostoianie == Sostoianie.stop) {
      print('Автомобиль остановился');
    } else if (sostoianie == Sostoianie.ehat) {
      print('Автомобиль едет');
    } else if (sostoianie == Sostoianie.povorot) {
      print('Автомобиль поворачивает');
    }
  }
}

// 8. Напишите базовый класс «Геометрическая фигура» и несколько производных классов (прямоугольник, треугольник, окружность и т.д.).
class GeometricheskayaFigura {
  double ploshad() {
    return 0;
  }
}

class Pryamougolnik extends GeometricheskayaFigura {
  double shirina;
  double vysota;
  
  Pryamougolnik(this.shirina, this.vysota);
  
  @override
  double ploshad() {
    return shirina * vysota;
  }
}

class Treugolnik extends GeometricheskayaFigura {
  double osnovanie;
  double vysota;
  
  Treugolnik(this.osnovanie, this.vysota);
  
  @override
  double ploshad() {
    return 0.5 * osnovanie * vysota;
  }
}

class Okruzhnost extends GeometricheskayaFigura {
  double radius;
  
  Okruzhnost(this.radius);
  
  @override
  double ploshad() {
    return 3.14 * radius * radius;
  }
}

// 9. Напишите класс для перевода значения числа из одной системы счисления (десятичная, шестнадцатеричная и восьмеричная) в другую.
class KonverterSistem {
  String desiatichnaya(int chislo) {
    return chislo.toString();
  }
  
  String shestnadcatirichnaya(int chislo) {
    return chislo.toRadixString(16).toUpperCase();
  }
  
  String vosmerichnaya(int chislo) {
    return chislo.toRadixString(8);
  }
  
  int vDesiatichnuyu(String chislo, int osnovanie) {
    return int.parse(chislo, radix: osnovanie);
  }
}

// 10. Напишите класс, который содержит список с геометрическими фигурами и позволяет находить фигуру с максимальной площадью.
class SpisokFigur {
  List<GeometricheskayaFigura> figury = [];
  
  void dobavitFiguru(GeometricheskayaFigura figura) {
    figury.add(figura);
  }
  
  GeometricheskayaFigura naitiMaxPloshad() {
    if (figury.isEmpty) {
      print('Нет фигур');
      return GeometricheskayaFigura();
    }
    
    GeometricheskayaFigura maxFigura = figury[0];
    for (var figura in figury) {
      if (figura.ploshad() > maxFigura.ploshad()) {
        maxFigura = figura;
      }
    }
    print('Максимальная площадь: ${maxFigura.ploshad()}');
    return maxFigura;
  }
}

// 11. Напишите класс «Стол», на который можно ставить различные столовые приборы (производные классы от базового) и убирать их со стола.
class StoloviyPribor {
  String nazvanie;
  
  StoloviyPribor(this.nazvanie);
}

class Nozh extends StoloviyPribor {
  Nozh() : super('Нож');
}

class Vilka extends StoloviyPribor {
  Vilka() : super('Вилка');
}

class Lozhka extends StoloviyPribor {
  Lozhka() : super('Ложка');
}

class Stol {
  List<StoloviyPribor> pribory = [];
  
  void postavit(StoloviyPribor pribor) {
    pribory.add(pribor);
    print('Поставил на стол: ${pribor.nazvanie}');
  }
  
  void ubrat(StoloviyPribor pribor) {
    if (pribory.contains(pribor)) {
      pribory.remove(pribor);
      print('Убрал со стола: ${pribor.nazvanie}');
    } else {
      print('Такого прибора нет на столе');
    }
  }
  
  void pokazatPribory() {
    print('На столе приборы:');
    for (var pribor in pribory) {
      print('- ${pribor.nazvanie}');
    }
  }
}

