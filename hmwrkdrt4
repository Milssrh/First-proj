    } else if (_sostoianie == Sostoianie.povorot) {
      print('Автомобиль поворачивает');
    }
  }
}

// 8. Напишите базовый класс «Геометрическая фигура» и несколько производных классов (прямоугольник, треугольник, окружность и т.д.).
abstract class GeometricheskayaFigura {
  double ploshad();
}
class Pryamougolnik extends GeometricheskayaFigura {
  double _shirina;
  double _vysota; 
  Pryamougolnik(this._shirina, this._vysota);
  @override
  double ploshad() {
    return _shirina * _vysota;
  }
}

class Treugolnik extends GeometricheskayaFigura {
  double _osnovanie;
  double _vysota;
  
  Treugolnik(this._osnovanie, this._vysota);
  
  @override
  double ploshad() {
    return 0.5 * _osnovanie * _vysota;
  }
}

class Okruzhnost extends GeometricheskayaFigura {
  double _radius;
  
  Okruzhnost(this._radius);
  
  @override
  double ploshad() {
    return 3.14 * _radius * _radius;
  }
}

// 9. Напишите класс для перевода значения числа из одной системы счисления (десятичная, шестнадцатеричная и восьмеричная) в другую.
class KonverterSistem {
  static String desiatichnaya(int chislo) {
    return chislo.toString();
  }
  
  static String shestnadcatirichnaya(int chislo) {
    return chislo.toRadixString(16).toUpperCase();
  }
  
  static String vosmerichnaya(int chislo) {
    return chislo.toRadixString(8);
  }
  
  static int vDesiatichnuyu(String chislo, int osnovanie) {
    return int.parse(chislo, radix: osnovanie);
  }
}

// 10. Напишите класс, который содержит список с геометрическими фигурами и позволяет находить фигуру с максимальной площадью.
class SpisokFigur {
  List<GeometricheskayaFigura> _figury = [];
  
  List<GeometricheskayaFigura> get figury => _figury;
  
  void dobavitFiguru(GeometricheskayaFigura figura) {
    _figury.add(figura);
  }
  
  GeometricheskayaFigura naitiMaxPloshad() {
    if (_figury.isEmpty) {
      print('Нет фигур');
      return Pryamougolnik(0, 0);
    }
    
    GeometricheskayaFigura maxFigura = _figury[0];
    for (var figura in _figury) {
      if (figura.ploshad() > maxFigura.ploshad()) {
        maxFigura = figura;
      }
    }
    print('Максимальная площадь: ${maxFigura.ploshad()}');
    return maxFigura;
  }
}

// 11. Напишите класс «Стол», на который можно ставить различные столовые приборы (производные классы от базового) и убирать их со стола.
class StoloviyPribor {
  String _nazvanie;
  
  StoloviyPribor(this._nazvanie);
  
  String get nazvanie => _nazvanie;
}

class Nozh extends StoloviyPribor {
  Nozh() : super('Нож');
}

class Vilka extends StoloviyPribor {
  Vilka() : super('Вилка');
}

class Lozhka extends StoloviyPribor {
  Lozhka() : super('Ложка');
}

class Stol {
  List<StoloviyPribor> _pribory = [];
  
  List<StoloviyPribor> get pribory => _pribory;
  
  void postavit(StoloviyPribor pribor) {
    _pribory.add(pribor);
    print('Поставил на стол: ${pribor.nazvanie}');
  }
  
  void ubrat(StoloviyPribor pribor) {
    if (_pribory.contains(pribor)) {
      _pribory.remove(pribor);
      print('Убрал со стола: ${pribor.nazvanie}');
    } else {
      print('Такого прибора нет на столе');
    }
  }
}

