// 1. Классы «Кружка» и «Человек». Дайте возможность человеку пить из кружки.
class Kruzhka {
  int _voda = 100;
  
  int get voda => _voda;
  
  void pit() {
    if (_voda >= 10) {
      _voda -= 10;
      print('Сделал глоток. Осталось $_voda мл');
    } else {
      print('Кружка пуста!');
    }
  }
}

class Chelovek {
  String _name;
  
  Chelovek(this._name);
  
  String get name => _name;
  
  void pitIzKruzhki(Kruzhka kruzhka) {
    print('$_name пьет из кружки');
    kruzhka.pit();
  }
}
// 2. Реализуйте класс «Шкаф», в состав которого входит несколько систем хранения. У пользователя должна быть возможность поместить вещи в шкаф и забрать их оттуда.
class Polka {
  List<String> _veshi = [];
  List<String> get veshi => _veshi;
  
  void polozhit(String vesh) {
    _veshi.add(vesh);
    print('Положил $vesh на полку');
  }
  
  String zabrat(String vesh) {
    if (_veshi.contains(vesh)) {
      _veshi.remove(vesh);
      print('Забрал $vesh с полки');
      return vesh;
    } else {
      print('$vesh не найдено');
      return '';
    }
  }
}

class Shkaf {
  List<Polka> _polki = [];
  
  Shkaf(int kolichestvoPolok) {
    for (int i = 0; i < kolichestvoPolok; i++) {
      _polki.add(Polka());
    }
  }
  
  void polozhitVShkaf(int nomerPolki, String vesh) {
    if (nomerPolki < _polki.length) {
      _polki[nomerPolki].polozhit(vesh);
    } else {
      print('Такой полки нет');
    }
  }
  
  void zabratIzShkafa(int nomerPolki, String vesh) {
    if (nomerPolki < _polki.length) {
      _polki[nomerPolki].zabrat(vesh);
    } else {
      print('Такой полки нет');
    }
  }
}
// 3. Реализуйте класс «Гриф» и «Блин». На гриф с левой и с правой стороны можно навешивать блины. В конструкторе класса «Гриф» передавайте параметр максимальной загрузки грифа по весу.
class Blin {
  int _ves;
  
  Blin(this._ves);
  
  int get ves => _ves;
}

class Grif {
  int _maxVes;
  int _tekushiyVes = 0;
  List<Blin> _levieBliny = [];
  List<Blin> _pravyeBliny = [];
  
  Grif(this._maxVes);
  
  int get maxVes => _maxVes;
  int get tekushiyVes => _tekushiyVes;
  
  bool navesitBl(Blin blin, String storona) {
    if (_tekushiyVes + blin.ves <= _maxVes) {
      if (storona == 'levo') {
        _levieBliny.add(blin);
      } else if (storona == 'pravo') {
        _pravyeBliny.add(blin);
      }
      _tekushiyVes += blin.ves;
      print('Навесил блин ${blin.ves}кг на $storona сторону');
      return true;
    } else {
      print('Превышен максимальный вес!');
      return false;
    }
  }
}

// 4. Реализуйте класс для конвертации денег из одной валюты в другую.
class KonverterValut {
  static double kursUSD = 75.5;
  static double kursEUR = 85.0;
  
  static double rubVUsd(double rub) {
    return rub / kursUSD;
  }
  
  static double rubVEur(double rub) {
    return rub / kursEUR;
  }
  
  static double usdVRub(double usd) {
    return usd * kursUSD;
  }
  
  static double eurVRub(double eur) {
    return eur * kursEUR;
  }
}

// 5. Посредством дженериков реализуйте класс «Гараж», где можно хранить различные объекты.
class Garazh<T> {
  List<T> _predmety = [];
  
  List<T> get predmety => _predmety;
  
  void polozhit(T predmet) {
    _predmety.add(predmet);
    print('Положил в гараж: $predmet');
  }
  
  T vzat() {
    if (_predmety.isNotEmpty) {
      T predmet = _predmety.removeLast();
      print('Взял из гаража: $predmet');
      return predmet;
    } else {
      print('Гараж пуст');
      return null as T;
    }
  }
}

// 6. Напишите класс, в котором перегружены все базовые арифметические операции и класс. Проверьте его работу.
class Chislo {
  int _znachenie;
  
  Chislo(this._znachenie);
  
  int get znachenie => _znachenie;
  
  Chislo operator +(Chislo other) {
    return Chislo(_znachenie + other._znachenie);
  }
  
  Chislo operator -(Chislo other) {
    return Chislo(_znachenie - other._znachenie);
  }
  
  Chislo operator *(Chislo other) {
    return Chislo(_znachenie * other._znachenie);
  }
  
  double operator /(Chislo other) {
    return _znachenie / other._znachenie;
  }
  
  @override
  String toString() {
    return '$_znachenie';
  }
}

// 7. Напишите класс «Автомобиль», для таких состояний, как: стоп, ехать, повернуть, используйте перечисления.
