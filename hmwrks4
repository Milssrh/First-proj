import socket
import threading
clients_lock = threading.Lock()
clients = [] 

def broadcast(message, sender_socket=None):
    with clients_lock:
        for client in clients:
            if client != sender_socket:  
                try:
                    client.send(message.encode('utf-8'))
                except:
                    if client in clients:
                        clients.remove(client)

def handle_client(client_socket, client_address):
    print(f"[{client_address}] Клиент подключился")
    
    try:
        welcome_msg = f"Добро пожаловать в чат! Сейчас в чате {len(clients)} участников."
        client_socket.send(welcome_msg.encode('utf-8'))
    except:
        pass
    
    broadcast(f" {client_address} присоединился к чату!", client_socket)
    
    while True:
        try:
            data = client_socket.recv(1024)
            if not data:  
                break
            
            message = data.decode('utf-8')
            print(f"[{client_address}] {message}")
            
            broadcast(f"{client_address}: {message}", client_socket)
            
        except ConnectionResetError:
            break
        except ConnectionAbortedError:
            break
        except Exception as e:
            print(f"Ошибка при обработке клиента {client_address}: {e}")
            break
    
    with clients_lock:
        if client_socket in clients:
            clients.remove(client_socket)
    
    client_socket.close()
    print(f"[{client_address}] Клиент отключился")
    
    broadcast(f" {client_address} покинул чат *")

def start_server(host='127.0.0.1', port=5000):
    server_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    server_socket.bind((host, port))
    server_socket.listen()
    
    print(f"Сервер запущен на {host}:{port}")
    print("Ожидание подключений...")
    
    while True:
        try:
            client_socket, client_address = server_socket.accept()
            
            with clients_lock:
                clients.append(client_socket)
            
            client_thread = threading.Thread(
                target=handle_client,
                args=(client_socket, client_address),
                daemon=True
            )
            client_thread.start()
            
        except KeyboardInterrupt:
            print("\n Сервер выключается...")
            break
        except Exception as e:
            print(f"Ошибка: {e}")
    
    with clients_lock:
        for client in clients:
            try:
                client.close()
            except:
                pass
        clients.clear()
    
    server_socket.close()
    print("Сервер остановлен")

if __name__ == "__main__":
    start_server()

